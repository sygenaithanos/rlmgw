{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "mcp__rlmgw__repo_select_context",
      "mcp__rlmgw__repo_tree",
      "mcp__rlmgw__repo_fingerprint",
      "mcp__rlmgw__vllm_status",
      "Bash(curl -s http://localhost:*)",
      "Bash(uv run *)",
      "Skill"
    ]
  },
  "env": {
    "RLMGW_REPO_ROOT": ".",
    "RLMGW_UPSTREAM_BASE_URL": "http://localhost:8000/v1",
    "RLMGW_MAX_CONTEXT_PACK_CHARS": "12000",
    "RLMGW_MAX_INTERNAL_CALLS": "3",
    "RLMGW_USE_RLM_CONTEXT_SELECTION": "true"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  }
}
